{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dead Reckoning",
  "version": "1.0.0",
  "identifier": "edu.osu.uwrt.deadreckoning",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Dead Reckoning — Woollett 50 m · RoboSub 2026",
        "width": 1500,
        "height": 940,
        "minWidth": 980,
        "minHeight": 620,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "RoboSub pool layout / riptide_mapping config editor",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
